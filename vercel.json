{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/product/:productId",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": ".*(facebookexternalhit|Facebot|Meta-ExternalAgent|Meta-ExternalFetcher|MessengerBot).*"
        }
      ],
      "destination": "/api/product-og?productId=:productId"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
